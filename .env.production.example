# ============================================================
# Blitz — Production Environment Variables
# Split across two services:
#   - Netlify (frontend): only NEXT_PUBLIC_* vars
#   - Render (backend): server-side vars
# ============================================================

# ═══════════════════════════════════════════════════════════════
# NETLIFY (Frontend) — set in Netlify Dashboard > Site > Environment
# ═══════════════════════════════════════════════════════════════

NEXT_PUBLIC_APP_URL=https://your-site.netlify.app
NEXT_PUBLIC_SERVER_URL=https://blitz-server.onrender.com
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_EXPLORER=https://testnet.monadvision.com
NEXT_PUBLIC_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_PAYMENT_ROUTER_ADDRESS=0x...

# ═══════════════════════════════════════════════════════════════
# RENDER (Backend) — set in Render Dashboard > Service > Environment
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=10000

# Supabase Cloud (get from supabase.com > Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key

# Monad
MONAD_RPC=https://testnet-rpc.monad.xyz

# Deployed Contracts
FACTORY_ADDRESS=0x...
ESCROW_ADDRESS=0x...
PAYMENT_ROUTER_ADDRESS=0x...

# Encryption (32 bytes hex — same key you used in dev)
ENCRYPTION_MASTER_KEY=your_32_byte_hex_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
# Secret for registering webhook endpoint
ADMIN_SECRET=your_admin_secret

# CORS — your Netlify frontend URL(s), comma-separated
ALLOWED_ORIGINS=https://your-site.netlify.app

# Public URL of THIS server (Render gives you this after first deploy)
PUBLIC_SERVER_URL=https://blitz-server.onrender.com

# Proxy hops (Render uses 1 reverse proxy)
TRUST_PROXY_HOPS=1

# Approval behavior
APPROVALS_FAIL_CLOSED=true
