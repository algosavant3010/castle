# ============================================================
# Blitz - Single Environment File (used by both frontend + server)
# Copy this to .env.local and fill in your values.
# ============================================================

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# --- Server ---
PORT=4000
NODE_ENV=development

# --- WalletConnect (get from https://cloud.walletconnect.com) ---
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# --- Monad ---
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_EXPLORER=https://testnet.monadvision.com
MONAD_RPC=https://testnet-rpc.monad.xyz

# --- Deployed Contracts ---
NEXT_PUBLIC_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_ESCROW_ADDRESS=0x...
NEXT_PUBLIC_PAYMENT_ROUTER_ADDRESS=0x...
FACTORY_ADDRESS=0x...
ESCROW_ADDRESS=0x...
PAYMENT_ROUTER_ADDRESS=0x...

# --- Supabase (get from `npx supabase start` output) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- Encryption (32 bytes hex) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=your_32_byte_hex_key

# --- Telegram (create bot via @BotFather) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Webhook secret (production only):
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=
# Admin secret for /api/telegram/register-webhook:
ADMIN_SECRET=

# --- CORS (comma-separated origins allowed to call the server) ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Server Public URL (for Telegram webhook registration) ---
PUBLIC_SERVER_URL=http://localhost:4000

# --- Security ---
# Number of reverse proxy hops (0 = direct, no proxy)
TRUST_PROXY_HOPS=0
# Block txs when approval required but no Telegram approver linked (true/false)
APPROVALS_FAIL_CLOSED=true

# --- Deployer (contract deployment only, never used at runtime) ---
DEPLOYER_PRIVATE_KEY=0x...
